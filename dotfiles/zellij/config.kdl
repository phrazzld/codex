// Zellij — optimized for mobile (mosh + Blink + Tailscale) and desktop.
// Priorities: session survival across disconnects, low UI overhead, big scrollback.

// --- UI: keep the layout lean, but let the chrome breathe --------------------
// Arrow separators render correctly here, so use the richer bar styling.
simplified_ui false
pane_frames false
default_layout "compact"

// --- Scrollback + session persistence ----------------------------------------
// Agents (Claude Code, etc.) dump a lot; mobile networks drop.
// session_serialization keeps panes+tabs+commands across zellij restarts.
// viewport serialization + scrollback bytes keeps context after resurrection.
scroll_buffer_size 100000
session_serialization true
pane_viewport_serialization true
scrollback_lines_to_serialize 10000

// --- Clipboard ---------------------------------------------------------------
// Zellij runs on the Mac; pbcopy targets the Mac clipboard regardless of
// which device is attached. Handy: copy on phone → paste on desktop later.
copy_command "pbcopy"
copy_clipboard "system"
copy_on_select false

// --- Touch / mouse -----------------------------------------------------------
// Blink forwards taps as mouse events — click panes/tabs directly from phone.
mouse_mode true

// --- Safety ------------------------------------------------------------------
// Terminal window close detaches the session instead of killing it.
on_force_close "detach"

// --- Startup -----------------------------------------------------------------
show_startup_tips false
show_release_notes false

// --- Theme -------------------------------------------------------------------
// Rose Pine main: soft contrast, dusty mauves, warm rose highlights.
themes {
    rose-pine {
        text_unselected {
            base 224 222 244
            background 31 29 46
            emphasis_0 246 193 119
            emphasis_1 156 207 216
            emphasis_2 49 116 143
            emphasis_3 196 167 231
