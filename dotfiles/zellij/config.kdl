            emphasis_0 235 111 146
            emphasis_1 246 193 119
            emphasis_2 156 207 216
            emphasis_3 196 167 231
        }
        ribbon_unselected {
            base 224 222 244
            background 64 61 82
            emphasis_0 235 111 146
            emphasis_1 144 140 170
            emphasis_2 156 207 216
            emphasis_3 196 167 231
        }
        table_title {
